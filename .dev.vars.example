# Copy this file to ".dev.vars" and fill in real values for local development.
# In production these are set via: wrangler secret put <NAME>
# NEVER commit the real .dev.vars file.

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=123456:ABC-DEF...

# A random secret string. Telegram sends it back in the
# "X-Telegram-Bot-Api-Secret-Token" header so we can verify the webhook.
# Generate e.g. with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Bot username without @ (used for group invite links)
BOT_USERNAME=CineMindBot

# Google AI Studio API key (Gemini)
GEMINI_API_KEY=AIza...

# Gemini models
MODEL_FAST=gemini-3.5-flash
MODEL_SMART=gemini-3.5-flash

# Free daily request limit per non-VIP user
DAILY_LIMIT=5

# Closed Telegram channel/chat id for VIP membership check (e.g. -100123456789)
VIP_CHAT_ID=

# Monetization links
PATREON_URL=https://patreon.com/...
BOOSTY_URL=https://boosty.to/...

# Optional: comma-separated admin Telegram ids (in addition to is_admin flag in DB)
ADMIN_IDS=
